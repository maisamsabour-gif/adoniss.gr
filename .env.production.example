# -----------------------------------------------------------------------------
# Core Django
# -----------------------------------------------------------------------------
ENV=production
DEBUG=0
DJANGO_SETTINGS_MODULE=adonis.settings
DJANGO_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
ALLOWED_HOSTS=adoniss.gr,www.adoniss.gr,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://adoniss.gr,https://www.adoniss.gr

# -----------------------------------------------------------------------------
# Database (PostgreSQL only)
# -----------------------------------------------------------------------------
DB_ENGINE=postgres
POSTGRES_DB=adoniss_prod
POSTGRES_USER=adoniss_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=120

# -----------------------------------------------------------------------------
# Redis (future cache/queue readiness)
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CACHE_BACKEND=django.core.cache.backends.locmem.LocMemCache
CACHE_LOCATION=adoniss-default-cache
CACHE_TIMEOUT=300

# -----------------------------------------------------------------------------
# Gunicorn
# -----------------------------------------------------------------------------
GUNICORN_WORKERS=4
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=60
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=5
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=100
GUNICORN_LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Security / SSL
# -----------------------------------------------------------------------------
SECURE_HSTS_SECONDS=31536000

# -----------------------------------------------------------------------------
# Optional external services
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05
GOOGLE_MAPS_API_KEY=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@adoniss.gr
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------------
# Backup
# -----------------------------------------------------------------------------
BACKUP_RETENTION_DAYS=14
BACKUP_HOUR_UTC=00
TZ=Asia/Tehran
