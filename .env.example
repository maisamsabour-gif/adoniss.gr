ENV=development
DEBUG=1
DJANGO_SECRET_KEY=change-me

ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# Database
DB_ENGINE=sqlite
SQLITE_PATH=/root/adonis_site/db.sqlite3
# DB_ENGINE=postgres
# POSTGRES_DB=adonis
# POSTGRES_USER=adonis
# POSTGRES_PASSWORD=change-me
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432
# DB_ENV_TAG=development

# Optional media on S3
USE_S3_MEDIA=0
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
AWS_S3_CUSTOM_DOMAIN=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Backup
BACKUP_LOCAL_DIR=/root/adonis_site/backups
BACKUP_RETENTION_DAYS=30
BACKUP_REQUIRE_OFFSITE=0
BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=development/database

# Security
SECURE_HSTS_SECONDS=31536000

# Optional monitoring
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05

# OpenAI — required for auto-translate to Turkish in Django Admin
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
